<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="unoq_braccio">
  <xacro:arg name="controllers_file" default=""/>
  <xacro:arg name="mesh_dir" default=""/>

  <material name="orange"><color rgba="1.0 0.34 0.02 1"/></material>
  <material name="white"><color rgba="0.86 0.86 0.82 1"/></material>
  <material name="black"><color rgba="0.02 0.02 0.025 1"/></material>
  <material name="lens_blue"><color rgba="0.08 0.28 0.55 1"/></material>

  <xacro:macro name="box_inertial" params="mass x y z">
    <inertial>
      <mass value="${mass}"/>
      <inertia
        ixx="${mass * (y * y + z * z) / 12.0}"
        iyy="${mass * (x * x + z * z) / 12.0}"
        izz="${mass * (x * x + y * y) / 12.0}"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="mesh_visual" params="filename material x y z rr rp ry">
    <visual>
      <origin xyz="${x} ${y} ${z}" rpy="${rr} ${rp} ${ry}"/>
      <geometry>
        <mesh filename="file://$(arg mesh_dir)/${filename}" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="${material}"/>
    </visual>
  </xacro:macro>

  <link name="world"/>

  <link name="base_link">
    <visual>
      <geometry><cylinder length="0.01" radius="0.053"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><cylinder length="0.01" radius="0.053"/></geometry>
    </collision>
    <inertial>
      <mass value="2"/>
      <inertia ixx="0.004" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.004"/>
    </inertial>
  </link>

  <joint name="base_fixed" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
  </joint>

  <link name="braccio_base_link">
    <xacro:mesh_visual filename="braccio_base.stl" material="orange" x="0" y="0.004" z="0" rr="0" rp="0" ry="3.1416"/>
    <collision>
      <origin xyz="0 0 0.035"/>
      <geometry><cylinder radius="0.065" length="0.07"/></geometry>
    </collision>
    <inertial>
      <mass value="2"/>
      <inertia ixx="0.004" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.004"/>
    </inertial>
  </link>

  <link name="shoulder_link">
    <xacro:mesh_visual filename="braccio_shoulder.stl" material="orange" x="-0.0045" y="0.0055" z="-0.026" rr="0" rp="0" ry="0"/>
    <collision>
      <origin xyz="0 0 0.06"/>
      <geometry><box size="0.055 0.08 0.12"/></geometry>
    </collision>
    <xacro:box_inertial mass="0.1" x="0.055" y="0.08" z="0.12"/>
  </link>

  <link name="elbow_link">
    <xacro:mesh_visual filename="braccio_elbow.stl" material="orange" x="-0.0045" y="0.005" z="-0.025" rr="0" rp="0" ry="0"/>
    <collision>
      <origin xyz="0 0 0.06"/>
      <geometry><box size="0.05 0.07 0.12"/></geometry>
    </collision>
    <xacro:box_inertial mass="0.1" x="0.05" y="0.07" z="0.12"/>
  </link>

  <link name="wrist_pitch_link">
    <xacro:mesh_visual filename="braccio_wrist_pitch.stl" material="orange" x="0.003" y="-0.0004" z="-0.024" rr="0" rp="0" ry="0"/>
    <collision>
      <origin xyz="0 0 0.035"/>
      <geometry><box size="0.045 0.055 0.07"/></geometry>
    </collision>
    <xacro:box_inertial mass="0.08" x="0.045" y="0.055" z="0.07"/>
  </link>

  <link name="wrist_roll_link">
    <xacro:mesh_visual filename="braccio_wrist_roll.stl" material="white" x="0.006" y="0" z="0" rr="0" rp="0" ry="0"/>
    <collision>
      <origin xyz="0 0 0.018"/>
      <geometry><box size="0.045 0.045 0.04"/></geometry>
    </collision>
    <xacro:box_inertial mass="0.08" x="0.045" y="0.045" z="0.04"/>
  </link>

  <link name="right_gripper_link">
    <xacro:mesh_visual filename="braccio_right_gripper.stl" material="white" x="0" y="-0.012" z="0.010" rr="0" rp="1.5708" ry="0"/>
    <collision>
      <origin xyz="0.035 -0.012 0.01"/>
      <geometry><box size="0.08 0.012 0.014"/></geometry>
    </collision>
    <xacro:box_inertial mass="0.03" x="0.08" y="0.012" z="0.014"/>
  </link>

  <link name="left_gripper_link">
    <xacro:mesh_visual filename="braccio_left_gripper.stl" material="white" x="0" y="-0.012" z="0" rr="0" rp="1.5708" ry="0"/>
    <collision>
      <origin xyz="0.035 -0.012 0"/>
      <geometry><box size="0.08 0.012 0.014"/></geometry>
    </collision>
    <xacro:box_inertial mass="0.03" x="0.08" y="0.012" z="0.014"/>
  </link>

  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry><box size="0.034 0.026 0.022"/></geometry>
      <material name="black"/>
    </visual>
    <visual>
      <origin xyz="0.018 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.008" length="0.006"/></geometry>
      <material name="lens_blue"/>
    </visual>
    <collision><geometry><box size="0.034 0.026 0.022"/></geometry></collision>
    <xacro:box_inertial mass="0.04" x="0.034" y="0.026" z="0.022"/>
  </link>

  <joint name="base" type="revolute">
    <axis xyz="0 0 1"/>
    <limit effort="2" lower="-1.5708" upper="1.5708" velocity="1"/>
    <origin xyz="0 0 0.01" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="braccio_base_link"/>
    <dynamics damping="0.1" friction="0.001"/>
  </joint>

  <joint name="shoulder" type="revolute">
    <axis xyz="1 0 0"/>
    <limit effort="2" lower="-1.309" upper="1.309" velocity="1"/>
    <origin xyz="0 -0.002 0.072" rpy="-1.5708 0 0"/>
    <parent link="braccio_base_link"/>
    <child link="shoulder_link"/>
    <dynamics damping="0.1" friction="0.001"/>
  </joint>

  <joint name="elbow" type="revolute">
    <axis xyz="1 0 0"/>
    <limit effort="2" lower="-1.5708" upper="1.5708" velocity="1"/>
    <origin xyz="0 0 0.125" rpy="-1.5708 0 0"/>
    <parent link="shoulder_link"/>
    <child link="elbow_link"/>
    <dynamics damping="0.1" friction="0.001"/>
  </joint>

  <joint name="wrist_vertical" type="revolute">
    <axis xyz="1 0 0"/>
    <limit effort="1" lower="-1.5708" upper="1.5708" velocity="1"/>
    <origin xyz="0 0 0.125" rpy="-1.5708 0 0"/>
    <parent link="elbow_link"/>
    <child link="wrist_pitch_link"/>
    <dynamics damping="0.1" friction="0.001"/>
  </joint>

  <joint name="wrist_rotation" type="revolute">
    <axis xyz="0 0 -1"/>
    <limit effort="1" lower="-1.5708" upper="1.5708" velocity="1"/>
    <origin xyz="0 0 0.06" rpy="0 0 1.5708"/>
    <parent link="wrist_pitch_link"/>
    <child link="wrist_roll_link"/>
    <dynamics damping="0.1" friction="0.001"/>
  </joint>

  <joint name="gripper" type="revolute">
    <axis xyz="0 -1 0"/>
    <limit effort="1" lower="0.1750" upper="1.2741" velocity="1"/>
    <origin xyz="0.010 0 0.03" rpy="0 -0.2967 0"/>
    <parent link="wrist_roll_link"/>
    <child link="right_gripper_link"/>
    <dynamics damping="0.1" friction="0.001"/>
  </joint>

  <joint name="left_gripper_mimic" type="revolute">
    <axis xyz="0 1 0"/>
    <mimic joint="gripper"/>
    <limit effort="1" lower="1.2741" upper="2.3732" velocity="1"/>
    <origin xyz="-0.010 0 0.03" rpy="0 3.4383 0"/>
    <parent link="wrist_roll_link"/>
    <child link="left_gripper_link"/>
    <dynamics damping="0.1" friction="0.001"/>
  </joint>

  <joint name="camera_mount" type="fixed">
    <parent link="wrist_roll_link"/>
    <child link="camera_link"/>
    <origin xyz="0.03 0 0.055" rpy="0 0 0"/>
  </joint>

  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="base">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="shoulder">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="elbow">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wrist_vertical">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="wrist_rotation">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="gripper">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="libgz_ros2_control-system.so" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(arg controllers_file)</parameters>
    </plugin>
  </gazebo>
</robot>
